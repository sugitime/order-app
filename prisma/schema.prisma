generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  APPROVER
}

enum LineItemStatus {
  PENDING
  APPROVED
  DENIED
  QUEUED
  ORDERING
  ORDERED
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(APPROVER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reviewedItems        LineItem[]           @relation("ReviewedBy")
  passwordResetTokens  PasswordResetToken[]
  orderActivityLogs    OrderActivityLog[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum OrderActivityAction {
  ORDER_SUBMITTED
  LINE_ITEM_APPROVED
  LINE_ITEM_DENIED
  LINE_ITEM_QUEUED
  LINE_ITEM_ORDERED
  LINE_ITEM_ORDER_FAILED
  LINE_ITEM_MANUAL_COMPLETE
  ORDER_DENIED
  ORDER_DELETED
}

model Order {
  id                  String    @id @default(cuid())
  requesterName       String
  requesterEmail      String    @default("")
  departmentName      String
  acknowledged        Boolean   @default(false)
  reviewSummarySentAt DateTime?
  deletedAt           DateTime?
  submittedAt         DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  lineItems    LineItem[]
  activityLogs OrderActivityLog[]
}

model OrderActivityLog {
  id            String              @id @default(cuid())
  orderId       String
  lineItemId    String?
  action        OrderActivityAction
  performedById String?
  details       String?
  createdAt     DateTime            @default(now())

  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lineItem    LineItem? @relation(fields: [lineItemId], references: [id], onDelete: SetNull)
  performedBy User?     @relation(fields: [performedById], references: [id])

  @@index([orderId])
  @@index([createdAt])
}

model LineItem {
  id              String         @id @default(cuid())
  orderId         String
  description     String
  amazonUrl       String
  quantity        Int
  justification   String
  unitPrice       Decimal?       @db.Decimal(10, 2)
  priceCurrency   String?        @default("USD")
  isPrimeEligible Boolean?
  priceFetchedAt  DateTime?
  priceLookupError String?
  status          LineItemStatus @default(PENDING)
  denialReason    String?
  reviewedById    String?
  reviewedAt      DateTime?
  queuedAt        DateTime?
  orderedAt       DateTime?
  amazonOrderId   String?
  trackingNumber  String?
  orderError      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order        Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewedBy   User?              @relation("ReviewedBy", fields: [reviewedById], references: [id])
  activityLogs OrderActivityLog[]
}

model AppConfig {
  id    String @id @default("singleton")
  value Json

  updatedAt DateTime @updatedAt
}