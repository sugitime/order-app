# Database (PostgreSQL — use Render Postgres connection string in production)
DATABASE_URL="postgresql://user:password@localhost:5432/order_app?schema=public"

# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Public URL of the app (used in notification emails)
APP_URL="http://localhost:3000"

# Initial admin account (used by db:seed)
SEED_ADMIN_EMAIL="kevin@sugiti.me"
SEED_ADMIN_PASSWORD="changeme123"

# Optional: Resend API key (alternative to storing in Admin → Settings)
# Use when Render free tier blocks SMTP ports 25/465/587
RESEND_API_KEY=""

# Render API key (for deployment scripts — do not commit the real value)
RENDER_API_KEY=""